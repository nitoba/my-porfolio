---

---

<section data-reveal class="flex flex-col gap-1.5 w-full lg:flex-row">
  <!-- Hero Copy -->
  <div
    class="flex flex-col gap-6 bg-[var(--color-bg-card)] p-6 border border-[var(--color-border)] md:p-10 lg:py-14 pl-14 pr-4! p lg:w-[852px] lg:shrink-0 lg:gap-8"
  >
    <!-- Eyebrow -->
    <div class="flex items-center gap-2">
      <i class="hgi-stroke hgi-source-code text-[var(--color-accent)] text-sm"
      ></i>
      <span
        class="text-[var(--color-accent)] text-[10px] font-semibold tracking-[0.5px] md:text-[11px] md:tracking-[1px] typewriter-cursor"
        data-typewriter="// 6+ ANOS CRIANDO PRODUTOS DIGITAIS, APPS E SISTEMAS COM IA APLICADA"
        data-typewriter-speed="30"></span>
    </div>

    <!-- Title -->
    <h1
      class="font-display text-[28px] font-bold text-[var(--color-text-primary)] tracking-[-0.5px] leading-[1.08] md:text-[36px] lg:text-[48px] lg:tracking-[-1px] lg:leading-[1.02]"
    >
      Eu projeto e desenvolvo experiencias web, mobile e IA com foco em produto
      real.
    </h1>

    <!-- Body -->
    <p
      class="text-[var(--color-text-secondary)] text-sm font-normal leading-[1.55] md:text-[15px]"
    >
      Full Stack Developer no Instituto Biosistemico. Minha stack passa por
      React, Next.js, Angular, Node.js, NestJS, React Native, Flutter e
      pipelines com RAG, agentes e automacoes inteligentes.
    </p>

    <!-- Actions -->
    <div class="flex flex-col gap-3 w-full sm:flex-row">
      <a
        href="#experiencia"
        class="group flex items-center justify-center gap-2.5 bg-[var(--color-accent)] px-5 py-3.5 transition-all duration-200 hover:brightness-110 hover:shadow-[0_0_20px_rgba(250,204,21,0.25)] hover:scale-[1.02] active:scale-95"
      >
        <span
          class="text-[var(--color-text-on-accent)] text-[13px] font-bold tracking-[1px]"
          >VER EXPERIENCIAS</span
        >
        <i
          class="hgi-stroke hgi-arrow-right-01 text-[var(--color-text-on-accent)] text-sm transition-transform duration-200 group-hover:translate-x-0.5"
        ></i>
      </a>
      <a
        href="https://github.com/nitoba"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-center gap-2.5 bg-[var(--color-border)] px-5 py-3.5 border border-[var(--color-accent)] transition-all duration-200 hover:bg-[var(--color-accent)]/10 hover:shadow-[0_0_20px_rgba(250,204,21,0.15)] hover:scale-[1.02] active:scale-95"
      >
        <i class="hgi-stroke hgi-github text-[var(--color-accent)] text-sm"></i>
        <span
          class="text-[var(--color-accent)] text-[13px] font-bold tracking-[1px]"
          >ABRIR GITHUB</span
        >
        <i
          class="hgi-stroke hgi-arrow-right-01 text-[var(--color-accent)] text-sm transition-transform duration-200 group-hover:translate-x-0.5"
        ></i>
      </a>
    </div>
  </div>

  <!-- Hero Visual -->
  <div
    class="flex flex-col gap-4 bg-[var(--color-bg-card-alt)] p-5 border-l-0 border-t-[3px] border-t-[var(--color-accent)] md:p-7 md:gap-[18px] lg:border-t-0 lg:border-l-[3px] lg:border-l-[var(--color-accent)] lg:flex-1"
  >
    <!-- Image placeholder -->
    <div
      class="w-full h-[200px] bg-[var(--color-bg-card)] overflow-hidden sm:h-[280px] lg:h-[360px]"
    >
      <img
        src="/images/hero.webp"
        alt="Code workspace"
        class="w-full h-full object-cover"
      />
    </div>

    <span class="text-[var(--color-text-primary)] text-sm font-medium">
      Builds for web, mobile, cloud and AI operations.
    </span>

    <p
      class="text-[var(--color-text-secondary)] text-[13px] font-normal leading-[1.5]"
    >
      Hoje atuo no Brasil, com experiencia em times remotos, projetos open
      source e plataformas de alto impacto.
    </p>
  </div>
</section>
