---

---

<section data-reveal class="flex flex-col gap-1.5 w-full lg:flex-row">
  <!-- Hero Copy -->
  <div
    class="flex flex-col gap-6 bg-(--color-bg-card) p-6 border border-(--color-border) md:p-10 lg:py-14 pl-14 pr-4! p lg:w-213 lg:shrink-0 lg:gap-8"
  >
    <!-- Eyebrow -->
    <div class="flex items-center gap-2">
      <i class="hgi-stroke hgi-source-code text-(--color-accent) text-sm"></i>
      <span
        class="text-(--color-accent) text-[10px] font-semibold tracking-[0.5px] md:text-[11px] md:tracking-[1px] typewriter-cursor"
        data-typewriter="// 6+ ANOS CRIANDO PRODUTOS DIGITAIS, APPS E SISTEMAS COM IA APLICADA"
        data-typewriter-speed="30"></span>
    </div>

    <!-- Title -->
    <h1
      class="font-display text-[28px] font-bold text-(--color-text-primary) tracking-[-0.5px] leading-[1.08] md:text-[36px] lg:text-[48px] lg:tracking-[-1px] lg:leading-[1.02]"
    >
      Eu projeto e desenvolvo experiencias web, mobile e IA com foco em produto
      real.
    </h1>

    <!-- Body -->
    <p
      class="text-(--color-text-secondary) text-sm font-normal leading-[1.55] md:text-[15px]"
    >
      Full Stack Developer no Instituto Biosistemico. Minha stack passa por
      React, Next.js, Angular, Node.js, NestJS, React Native, Flutter e
      pipelines com RAG, agentes e automacoes inteligentes.
    </p>

    <!-- Actions -->
    <div class="flex flex-col gap-3 w-full sm:flex-row">
      <a
        href="#experiencia"
        class="group flex items-center justify-center gap-2.5 bg-(--color-accent) px-5 py-3.5 transition-all duration-200 hover:brightness-110 hover:shadow-[0_0_20px_rgba(250,204,21,0.25)] hover:scale-[1.02] active:scale-95"
      >
        <span class="text-(--color-text-on-accent) text-sm font-bold mt-1"
          >VER EXPERIENCIAS</span
        >
        <i
          class="hgi-stroke hgi-arrow-right-01 text-(--color-text-on-accent) text-sm transition-transform duration-200 group-hover:translate-x-0.5"
        ></i>
      </a>
      <a
        href="https://github.com/nitoba"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-center gap-2.5 bg-(--color-border) px-5 py-3.5 border border-(--color-accent) transition-all duration-200 hover:bg-(--color-accent)/10 hover:shadow-[0_0_20px_rgba(250,204,21,0.15)] hover:scale-[1.02] active:scale-95"
      >
        <i class="hgi-stroke hgi-github text-(--color-accent) text-sm"></i>
        <span class="text-(--color-accent) text-sm font-bold mt-1"
          >ABRIR GITHUB</span
        >
        <i
          class="hgi-stroke hgi-arrow-right-01 text-(--color-accent) text-sm transition-transform duration-200 group-hover:translate-x-0.5"
        ></i>
      </a>
    </div>
  </div>

  <!-- Hero Visual -->
  <div
    class="flex flex-col gap-4 bg-(--color-bg-card-alt) p-5 border-l-0 border-t-[3px] border-t-(--color-accent) md:p-7 md:gap-4.5 lg:border-t-0 lg:border-l-[3px] lg:border-l-(--color-accent) lg:flex-1"
  >
    <!-- Image placeholder -->
    <div
      class="w-full h-50 bg-(--color-bg-card) overflow-hidden sm:h-70 lg:h-90"
    >
      <img
        src="/images/hero.webp"
        alt="Code workspace"
        class="w-full h-full object-cover"
      />
    </div>

    <span class="text-(--color-text-primary) text-sm font-medium">
      Builds for web, mobile, cloud and AI operations.
    </span>

    <p
      class="text-(--color-text-secondary) text-[13px] font-normal leading-[1.5]"
    >
      Hoje atuo no Brasil, com experiencia em times remotos, projetos open
      source e plataformas de alto impacto.
    </p>
  </div>
</section>
